# Copy this file to .env and fill in your values.
# Load with: export $(cat .env | xargs)   or use python-dotenv.

# GCP project that contains your BigQuery dataset
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# BigQuery dataset where MMM tables will be created
BQ_DATASET=your-dataset-name

# Path to a service account key JSON (optional — omit if using `gcloud auth application-default login`)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini Data Analytics agent resource ID
BQ_AGENT_ID=your-agent-id-here
